{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "BlurAutoClicker",
  "version": "3.2.0",
  "identifier": "BlurAutoClicker",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
      "windows": [
        {
          "label": "main",
          "title": "BlurAutoClicker",
          "width": 520,
          "height": 235,
          "resizable": false,
          "fullscreen": false,
          "decorations": false,
          "transparent": true
        }
        
      ],
      "security": {
        "csp": null
      }
    },
    "plugins":{
      "updater": {
      "endpoints": [
          "https://github.com/Blur009/Blur-AutoClicker/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDIyREY0RTc2QTU4Qjc1N0UKUldSK2RZdWxkazdmSW1IQmI4ZVMwOTRzWnBiVENhMFNYMFRtN0V4R3N0Q2JXQUdqM2t4VnRnNUYK"
      },
      "windows": {
        "installMode": "passive"
      }
    },
    "bundle": {
      "active": true,
      "targets": "nsis",
      "createUpdaterArtifacts": true,
      "icon": ["icons/icon.ico"]
    }
}